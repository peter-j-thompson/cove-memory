# Open Memory — Environment Configuration

# Database
DB_HOST=localhost
DB_PORT=5433
DB_NAME=open_memory
DB_USER=open_memory
DB_PASSWORD=your_secure_password_here

# Ollama embeddings (local, free)
OLLAMA_URL=http://localhost:11434
EMBEDDING_MODEL=bge-m3

# LLM for consolidation (optional but recommended)
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_CONSOLIDATION_MODEL=claude-sonnet-4-6

# API auth
# API_KEY=your_api_key_here

# Markdown workspace (optional — for markdown memory integration)
# MARKDOWN_MEMORY_DIR=./workspace
# MARKDOWN_WORKSPACE=./workspace
